# ─── PostgreSQL ───────────────────────────────────────────────────────
# postgres スーパーユーザーのパスワード
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ─── JWT ──────────────────────────────────────────────────────────────
# JWT 署名キー (32文字以上)
# 生成: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters

# anon キー (上の JWT_SECRET で署名した JWT)
# 生成方法:
#   pip install pyjwt
#   python3 -c "import jwt,time; t=int(time.time()); print(jwt.encode({'role':'anon','iss':'supabase','iat':t,'exp':t+315360000}, 'YOUR_JWT_SECRET', algorithm='HS256'))"
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── ドメイン ─────────────────────────────────────────────────────────
# Caddy が Listen するドメイン (実ドメインなら自動 HTTPS)
# ローカル開発: localhost
DOMAIN=localhost

# ─── CORS ─────────────────────────────────────────────────────────────
# フロントエンドの Origin (GitHub Pages の URL)
# 例: https://sta-kak.github.io
CORS_ORIGIN=https://sta-kak.github.io
